rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    match /users/{uid} {
      allow read: if ownsUserDoc(uid) || isAdmin();
      allow create: if ownsUserDoc(uid)
        && request.resource.data.uid == uid
        && request.resource.data.feeWalletBalance == 0
        && request.resource.data.currency in ['USD', 'USDT'];
      allow update: if ownsUserDoc(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'uid',
          'role',
          'admin',
          'feeWalletBalance',
          'createdAt'
        ]);
      allow delete: if false;

      match /botInstances/{botId} {
        allow read: if ownsUserDoc(uid) || isAdmin();
        allow create, update, delete: if false;
      }

      match /tradeLedger/{entryId} {
        allow read: if ownsUserDoc(uid) || isAdmin();
        allow create, update, delete: if false;
      }

      match /fundingRequests/{requestId} {
        allow read: if ownsUserDoc(uid) || isAdmin();
        allow create: if ownsUserDoc(uid)
          && request.resource.data.keys().hasOnly(['amount', 'status', 'createdAt', 'updatedAt'])
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.status == 'pending';
        allow update, delete: if false;
      }

      match /exchangeAccounts/{accountId} {
        allow read, write: if false;
      }
    }
  }
}